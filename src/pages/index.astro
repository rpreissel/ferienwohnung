---
import { getEntry } from "astro:content";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Highlights from "../components/Highlights.astro";
import Description from "../components/Description.astro";
import Gallery from "../components/Gallery.astro";
import Amenities from "../components/Amenities.astro";
import Location from "../components/Location.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Lightbox from "../components/Lightbox.astro";
import "../styles/global.css";

const apt = await getEntry("apartment", "apartment");
if (!apt) throw new Error("Content not found: src/content/apartment.md");
const d = apt.data;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{d.seoTitle}</title>
    <meta name="description" content={d.seoDescription} />
    <link rel="canonical" href="https://ferienwohnung.preissel-hh.de/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ferienwohnung.preissel-hh.de/" />
    <meta property="og:title" content={d.seoTitle} />
    <meta property="og:description" content={d.seoDescription} />
    <meta property="og:image" content="https://ferienwohnung.preissel-hh.de/images/living-room.jpg" />
    <meta property="og:image:width" content="720" />
    <meta property="og:image:height" content="609" />
    <meta property="og:image:alt" content="Helles Wohn-/Schlafzimmer der Ferienwohnung Hamburg-Wellingsbüttel" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Ferienwohnung Wellingsbüttel" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={d.seoTitle} />
    <meta name="twitter:description" content={d.seoDescription} />
    <meta name="twitter:image" content="https://ferienwohnung.preissel-hh.de/images/living-room.jpg" />
    <meta name="twitter:image:alt" content="Helles Wohn-/Schlafzimmer der Ferienwohnung Hamburg-Wellingsbüttel" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "additionalType": "Apartment",
      "identifier": d.registrationNumber,
      "name": "Ferienwohnung Wellingsbüttel – Hamburg",
      "description": d.description.paragraphs.join(" "),
      "url": "https://ferienwohnung.preissel-hh.de/",
      "latitude": 53.64500,
      "longitude": 10.07900,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Eckerkamp 14",
        "postalCode": "22391",
        "addressLocality": "Hamburg",
        "addressRegion": "Hamburg",
        "addressCountry": "DE"
      },
      "image": [
        "https://ferienwohnung.preissel-hh.de/images/exterior.jpg",
        "https://ferienwohnung.preissel-hh.de/images/living-room.jpg",
        "https://ferienwohnung.preissel-hh.de/images/sofa.jpg",
        "https://ferienwohnung.preissel-hh.de/images/kitchen-dining.jpg",
        "https://ferienwohnung.preissel-hh.de/images/bathroom.jpg",
        "https://ferienwohnung.preissel-hh.de/images/bathroom2.jpg",
        "https://ferienwohnung.preissel-hh.de/images/desk.jpg",
        "https://ferienwohnung.preissel-hh.de/images/coffee-machine.jpg",
        "https://ferienwohnung.preissel-hh.de/images/induction-hob.jpg",
        "https://ferienwohnung.preissel-hh.de/images/dishwasher.jpg",
        "https://ferienwohnung.preissel-hh.de/images/washer-dryer.jpg"
      ],
      "checkinTime": "15:00:00+02:00",
      "checkoutTime": "11:00:00+02:00",
      "knowsLanguage": ["de-DE"],
      "containsPlace": {
        "@type": "Accommodation",
        "additionalType": "EntirePlace",
        "occupancy": {
          "@type": "QuantitativeValue",
          "value": 2
        },
        "numberOfBedrooms": 1,
        "numberOfBathroomsTotal": 1,
        "numberOfRooms": 3,
        "bed": [{
          "@type": "BedDetails",
          "numberOfBeds": 1,
          "typeOfBed": "Queen"
        }],
        "amenityFeature": [
          { "@type": "LocationFeatureSpecification", "name": "wifi", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "kitchen", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "washerDryer", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "tv", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "heating", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "crib", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "selfCheckinCheckout", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "smokingAllowed", "value": false },
          { "@type": "LocationFeatureSpecification", "name": "elevator", "value": false },
          { "@type": "LocationFeatureSpecification", "name": "balcony", "value": false },
          { "@type": "LocationFeatureSpecification", "name": "internetType", "value": "Free" },
          { "@type": "LocationFeatureSpecification", "name": "parkingType", "value": "Free" },
          { "@type": "LocationFeatureSpecification", "name": "licenseNum", "value": d.registrationNumber }
        ]
      }
    })} />
  </head>
  <body>
    <Header brandName="Ferienwohnung Wellingsbüttel" email={d.email} />

    <main id="top">
      <Hero
        eyebrow={d.eyebrow}
        title={d.title}
        subtitle={d.subtitle}
        stats={d.stats}
        pricing={d.pricing}
      />

      <Highlights highlights={d.highlights} />

      <Description
        heading={d.description.heading}
        paragraphs={d.description.paragraphs}
        note={d.description.note}
      />

      <Gallery />

      <Amenities amenities={d.amenities} />

      <Location
        heading={d.location.heading}
        text={d.location.text}
        checklist={d.location.checklist}
      />

      <Contact
        heading={d.contact.heading}
        text={d.contact.text}
        email={d.email}
        airbnbUrl={d.contact.airbnbUrl}
      />
    </main>

    <Footer registrationNumber={d.registrationNumber} />
    <Lightbox />
  </body>
</html>
