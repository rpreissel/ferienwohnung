---
import { Image } from "astro:assets";
import livingRoom from "../assets/images/living-room.jpg";
import sofa from "../assets/images/sofa.jpg";
import inductionHob from "../assets/images/induction-hob.jpg";
import coffeeMachine from "../assets/images/coffee-machine.jpg";
import dishwasher from "../assets/images/dishwasher.jpg";
import bathroom2 from "../assets/images/bathroom2.jpg";
---

<section class="gallery">
  <Image
    src={livingRoom}
    alt="Wohn-/Schlafzimmer"
    loading="lazy"
    widths={[400, 720]}
    sizes="(max-width: 600px) 50vw, 25vw"
  />
  <Image
    src={sofa}
    alt="Schlafsofa"
    loading="lazy"
    widths={[400, 720]}
    sizes="(max-width: 600px) 50vw, 25vw"
  />
  <Image
    src={inductionHob}
    alt="Induktionsherd und Spüle"
    loading="lazy"
    widths={[400, 720]}
    sizes="(max-width: 600px) 50vw, 25vw"
  />
  <Image
    src={coffeeMachine}
    alt="Kaffeemaschine"
    loading="lazy"
    widths={[400, 720]}
    sizes="(max-width: 600px) 50vw, 25vw"
  />
  <Image
    src={dishwasher}
    alt="Spülmaschine und Kühlschrank mit Gefrierfach"
    loading="lazy"
    widths={[400, 720]}
    sizes="(max-width: 600px) 50vw, 25vw"
  />
  <Image
    src={bathroom2}
    alt="Badezimmer"
    loading="lazy"
    widths={[400, 720]}
    sizes="(max-width: 600px) 50vw, 25vw"
  />
</section>
