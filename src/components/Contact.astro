---
export interface Props {
  heading: string;
  text: string;
  email: string;
  airbnbUrl: string;
}

const { heading, text, email, airbnbUrl } = Astro.props;
---

<section id="kontakt" class="contact-banner">
  <div class="contact-inner">
    <div class="contact-text">
      <p class="eyebrow" style="color: rgba(255,255,255,0.65);">Verfügbarkeit & Buchung</p>
      <h2>{heading}</h2>
      <p>{text}</p>
    </div>
    <div class="contact-actions">
      <a class="contact-btn primary" href={`mailto:${email}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        Direkt anfragen
      </a>
      <div class="contact-airbnb-wrapper">
        <a class="contact-btn secondary" href={airbnbUrl} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Auf Airbnb ansehen
        </a>
        <p class="contact-hint">Dort finden Sie auch unseren Belegungskalender</p>
      </div>
    </div>
  </div>
</section>
