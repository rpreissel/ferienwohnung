---
export interface Props {
  heading: string;
  text: string;
  email: string;
}

const { heading, text, email } = Astro.props;
---

<section id="kontakt" class="contact-banner">
  <div class="contact-inner">
    <div class="contact-text">
      <p class="eyebrow" style="color: rgba(255,255,255,0.65);">Direkte Anfrage</p>
      <h2>{heading}</h2>
      <p>{text}</p>
    </div>
    <div class="contact-actions">
      <a class="contact-link email" href={`mailto:${email}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        {email}
      </a>
    </div>
  </div>
</section>
