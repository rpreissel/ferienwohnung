---
import { Image } from "astro:assets";
import exterior from "../assets/images/exterior.jpg";
import kitchenDining from "../assets/images/kitchen-dining.jpg";
import bathroom from "../assets/images/bathroom.jpg";
import desk from "../assets/images/desk.jpg";

export interface Props {
  heading: string;
  paragraphs: string[];
  note: string;
}

const { heading, paragraphs, note } = Astro.props;
---

<section class="section description-section">
  <div class="desc-text">
    <div class="section-label">Über die Unterkunft</div>
    <h2>{heading}</h2>
    {paragraphs.map((p) => <p>{p}</p>)}
    <p class="desc-note">{note}</p>
  </div>
  <div class="desc-images">
    <Image
      src={exterior}
      alt="Außenansicht des Hauses"
      loading="lazy"
      widths={[400, 720]}
      sizes="(max-width: 600px) 100vw, 50vw"
    />
    <Image
      src={kitchenDining}
      alt="Küche mit Essplatz"
      loading="lazy"
      widths={[400, 720]}
      sizes="(max-width: 600px) 100vw, 50vw"
    />
    <Image
      src={bathroom}
      alt="Bad mit Dusche"
      loading="lazy"
      widths={[400, 720]}
      sizes="(max-width: 600px) 100vw, 50vw"
    />
    <Image
      src={desk}
      alt="Arbeitsbereich"
      loading="lazy"
      widths={[400, 720]}
      sizes="(max-width: 600px) 100vw, 50vw"
    />
  </div>
</section>
