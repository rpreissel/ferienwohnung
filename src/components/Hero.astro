---
import { Image } from "astro:assets";
import livingRoom from "../assets/images/living-room.jpg";

export interface Stat {
  value: string;
  label: string;
}

export interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  stats: Stat[];
  pricing: { perNight: number; cleaning: number; cancellation: string };
}

const { eyebrow, title, subtitle, stats, pricing } = Astro.props;
---

<section class="hero">
  <div class="hero-image">
    <Image
      src={livingRoom}
      alt="Helles Wohn-/Schlafzimmer mit TV und Dachschräge"
      loading="eager"
      widths={[720, 1080]}
      sizes="(max-width: 860px) 100vw, 60vw"
    />
  </div>

  <div class="hero-content">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-sub">{subtitle}</p>

    <div class="hero-stats">
      {stats.map((stat, i) => (
        <>
          <div class="stat">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
          {i < stats.length - 1 && <div class="stat-divider"></div>}
        </>
      ))}
    </div>

    <div class="hero-actions">
      <a class="button primary" href="#kontakt">Jetzt unverbindlich anfragen</a>
      <a class="button secondary" href="#ausstattung">Details ansehen</a>
    </div>

    <div class="hero-pricing">
      <div class="price-item">
        <span class="price-amount">{pricing.perNight} €</span>
        <span class="price-label">pro Nacht</span>
      </div>
      <div class="price-divider"></div>
      <div class="price-item">
        <span class="price-amount">{pricing.cleaning} €</span>
        <span class="price-label">Endreinigung</span>
      </div>
    </div>
    <p class="cancellation-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      {pricing.cancellation}
    </p>
  </div>
</section>

<style>
  .hero-pricing {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.85rem 1rem;
    background: var(--brand-light);
    border-radius: var(--radius-sm);
    margin-top: 0.5rem;
  }

  .price-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .price-amount {
    font-family: "Bricolage Grotesque", sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .price-label {
    font-size: 0.72rem;
    color: var(--brand);
    font-weight: 500;
  }

  .price-divider {
    width: 1px;
    height: 28px;
    background: var(--brand);
    opacity: 0.2;
  }

  .cancellation-note {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  .cancellation-note svg {
    flex-shrink: 0;
    width: 13px;
    height: 13px;
    margin-top: 2px;
    color: var(--subtle);
  }
</style>
